# Production Environment Configuration for Voice System
# Copy to .env.production for deployment

# ─────────────────────────────────────────────────────────────────
# VOICE SYSTEM - PRODUCTION CONFIGURATION
# ─────────────────────────────────────────────────────────────────

# Service Rate Limiting (adjust based on your API quotas)
GEMINI_REQUEST_DELAY_MS=200
VOICE_BATCH_SIZE=5
OPENAI_REQUEST_DELAY_MS=100

# Circuit Breaker Settings
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT_MS=30000

# Cache Configuration
TTS_CACHE_MAX_SIZE=2000
TTS_CACHE_TTL_HOURS=168
ENHANCEMENT_CACHE_MAX_SIZE=500
ENHANCEMENT_CACHE_TTL_HOURS=24

# Rate Limiting per Service
GEMINI_RATE_LIMIT_PER_MINUTE=30
OPENAI_RATE_LIMIT_PER_MINUTE=50

# Health Check Configuration
HEALTH_CHECK_WINDOW_MINUTES=5
MAX_METRICS_STORED=10000

# Performance Thresholds
MAX_ACCEPTABLE_RESPONSE_TIME_MS=5000
MAX_ACCEPTABLE_ERROR_RATE=0.1

# Monitoring and Alerting
ENABLE_PERFORMANCE_MONITORING=true
ENABLE_ERROR_ALERTING=true
ALERT_WEBHOOK_URL=your_slack_webhook_or_discord_url

# ─────────────────────────────────────────────────────────────────
# DATABASE & REDIS - PRODUCTION
# ─────────────────────────────────────────────────────────────────

# Use production database URLs
DATABASE_URL="postgresql://username:password@host:port/database"
REDIS_URL="redis://username:password@host:port"

# Connection pool settings for high load
DATABASE_POOL_SIZE=20
REDIS_POOL_SIZE=10

# ─────────────────────────────────────────────────────────────────
# API KEYS - PRODUCTION
# ─────────────────────────────────────────────────────────────────

# Use production API keys with higher quotas
OPENAI_API_KEY="sk-proj-your-production-openai-key"
NEXT_PUBLIC_GEMINI_API_KEY="your-production-gemini-key"

# Auth keys
BETTER_AUTH_SECRET="your-super-secure-production-secret"
BETTER_AUTH_URL="https://yourdomain.com"

# ─────────────────────────────────────────────────────────────────
# DEPLOYMENT SETTINGS
# ─────────────────────────────────────────────────────────────────

NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1

# Logging
LOG_LEVEL=info
ENABLE_DEBUG_LOGGING=false

# Security
CORS_ORIGIN="https://yourdomain.com"
SECURE_HEADERS=true