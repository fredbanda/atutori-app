generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // eatutori specific fields
  grade        Int? // 1-12 for grade levels
  gradeGroup   String? // "primary-early", "primary-mid", "primary-upper", "high-junior", "high-senior"
  level        Int       @default(1)
  xp           Int       @default(0)
  streakDays   Int       @default(0)
  lastActiveAt DateTime?
  onboarded    Boolean   @default(false)

  sessions Session[]
  accounts Account[]

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

// Media uploaded by tutors/parents for students
model Media {
  id           String   @id @default(cuid())
  title        String
  description  String?
  url          String // Video URL (YouTube, Vimeo, etc.)
  thumbnailUrl String?
  duration     Int? // Duration in seconds
  gradeGroup   String // Target grade group
  subjectId    String? // Optional subject association
  uploadedById String // Tutor/Parent who uploaded
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignments MediaAssignment[]

  @@map("media")
}

// Many-to-many: Media assigned to students
model MediaAssignment {
  id            String    @id @default(cuid())
  mediaId       String
  media         Media     @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  studentId     String // User ID of student
  assignedById  String // Tutor/Parent who assigned
  watched       Boolean   @default(false)
  watchedAt     DateTime?
  quizCompleted Boolean   @default(false)
  quizScore     Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([mediaId, studentId])
  @@map("media_assignment")
}

// Subscription packages
model Package {
  id          String   @id @default(cuid())
  name        String
  description String
  price       Int // Price in cents
  interval    String // "monthly", "yearly", "lifetime"
  features    String[] // List of features
  maxStudents Int      @default(1) // Max students per subscription
  isPopular   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscriptions Subscription[]

  @@map("package")
}

// User subscriptions
model Subscription {
  id                 String    @id @default(cuid())
  userId             String
  packageId          String
  package            Package   @relation(fields: [packageId], references: [id])
  status             String // "active", "cancelled", "expired", "trialing"
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelledAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@map("subscription")
}

// NEW: The curated prompt template (your IP — admin-created)
model SubjectPrompt {
  id             String  @id @default(cuid())
  subjectId      String // e.g. "math", "science", "english"
  subjectName    String // e.g. "Mathematics"
  cambridgeStage String // "KS1" | "KS2" | "KS3" | "IGCSE" | "AS" | "A2"
  grade          Int // 1–12 (maps to stage automatically)
  isActive       Boolean @default(true)
  version        Int     @default(1) // bump when you improve a prompt

  // The prompt itself
  systemPrompt String // Instructions to Claude on role, tone, format
  userPrompt   String // The actual lesson generation instruction

  // Lesson shape controls
  contentSteps   Int     @default(2) // how many content slides
  quizCount      Int     @default(3) // how many quiz questions
  difficultyHint String? // "foundational" | "standard" | "extended"
  topicFocus     String? // e.g. "fractions", "photosynthesis" — optional override

  // Output format instruction (tells Claude exact JSON shape to return)
  outputSchema String // JSON string of the expected lesson structure

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lessonCaches LessonCache[]

  @@unique([subjectId, grade, version])
  @@map("subject_prompt")
}

// NEW: Generated lesson stored in DB + keyed in Redis
model LessonCache {
  id       String        @id @default(cuid())
  promptId String
  prompt   SubjectPrompt @relation(fields: [promptId], references: [id])

  redisKey String @unique
  cacheKey String

  generatedContent Json
  model String @default("claude") // "openai" | "claude" | "gemini"
  modelVersion     String? // "gpt-4o", "claude-3-opus", etc.

  promptVersion   Int
  difficultyLevel String? // "easy" | "medium" | "hard"

  qualityScore Float? // system-evaluated later (important)

  expiresAt  DateTime?
  useCount   Int       @default(0)
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  attempts LessonAttempt[]

  @@index([cacheKey])
  @@map("lesson_cache")
}

// NEW: Every time a student completes or attempts a lesson
model LessonAttempt {
  id      String      @id @default(cuid())
  userId  String
  cacheId String
  cache   LessonCache @relation(fields: [cacheId], references: [id])

  subjectId      String
  grade          Int
  cambridgeStage String

  score          Int
  totalQuestions Int
  xpEarned       Int     @default(0)
  passed         Boolean @default(false)

  answers         Json
  durationSeconds Int?

  // 🔥 NEW — ADAPTIVE SIGNALS
  model         String // duplicate for fast querying
  promptVersion Int

  difficultyLevel String? // snapshot from cache
  attemptNumber   Int     @default(1)

  improvement     Float? // (current - previous score)
  confidenceLevel Float? // derived later

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([userId])
  @@index([userId, subjectId])
  @@index([subjectId, grade, model]) // 🔥 analytics speed
  @@map("lesson_attempt")
}

// Full Cambridge learner profile — supports credit transfer
model LearnerProfile {
  id     String @id @default(cuid())
  userId String @unique

  // Personal details
  dateOfBirth        DateTime?
  nationality        String?
  countryOfResidence String?
  firstLanguage      String?
  gender             String? // "male" | "female" | "prefer_not_to_say"

  // Cambridge exam registration details
  centreName      String? // School / exam centre name
  centreNumber    String? // Cambridge-assigned centre number
  candidateNumber String? // Assigned at exam registration
  cambridgeStage  String? // "KS1" | "KS2" | "KS3" | "IGCSE" | "AS" | "A2"

  // Parent / guardian contact
  guardianName     String?
  guardianEmail    String?
  guardianPhone    String?
  guardianRelation String? // "mother" | "father" | "guardian"

  // Credit transfer — previous Cambridge results
  previousResults Json? // [{subject, code, grade, year, stage}]

  completedAt DateTime? // null = profile not yet finished
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("learner_profile")
}

model ModelPerformance {
  id        String @id @default(cuid())
  subjectId String
  grade     Int
  model     String

  avgScore    Float
  attempts    Int
  successRate Float

  lastUpdated DateTime @updatedAt

  @@unique([subjectId, grade, model])
  @@map("model_performance")
}

model UserModelPreference {
  id        String @id @default(cuid())
  userId    String
  subjectId String
  model     String

  avgScore   Float
  usageCount Int

  updatedAt DateTime @updatedAt

  @@unique([userId, subjectId, model])
  @@map("user_model_preference")
}

model PromptPerformance {
  id       String @id @default(cuid())
  promptId String
  model    String

  avgScore    Float
  usageCount  Int
  successRate Float

  @@unique([promptId, model])
  @@map("prompt_performance")
}

model AudioCache {
  id        String   @id @default(cuid())
  text      String   @unique
  voice     String   // "child_friendly_1"
  audioUrl  String   // stored in S3 / CDN
  createdAt DateTime @default(now())

  @@map("audio_cache")
}